# Konfiguration des FHEM-MCP-Servers (Docker/Portainer).
# Werte kopieren nach .env bzw. in die Portainer-Stack-Umgebung eintragen.

# Basis-URL der abgeschotteten FHEMWEB-Instanz (inkl. /fhem), nur intern erreichbar.
FHEMMCP_FHEM_URL=http://fhem:8083/fhem

# HTTP-Basic-Auth dieser FHEMWEB-Instanz (empfohlen).
FHEMMCP_FHEM_USER=mcp
FHEMMCP_FHEM_PASSWORD=change-me

# TLS-Prüfung, falls FHEMWEB per https läuft.
FHEMMCP_FHEM_VERIFY_TLS=true
# FHEMMCP_FHEM_CA_FILE=/certs/ca.pem

# MCP-Endpunktpfad (hinter dem Reverse Proxy).
FHEMMCP_MCP_PATH=/mcp

# Host-Port, auf den der Container veröffentlicht wird (nur fürs Port-Mapping in
# docker-compose). Ändern, falls 8000 auf der NAS schon belegt ist; der Reverse
# Proxy muss dann auf diesen Port zeigen. Container-intern bleibt es 8000.
FHEMMCP_HOSTPORT=8000

# Proxy-Robustheit (Defaults passen für einen Reverse Proxy wie Synology):
#   JSON statt SSE, stateless, DNS-Rebinding-Schutz aus (Host kommt vom Proxy).
# FHEMMCP_JSON_RESPONSE=true
# FHEMMCP_STATELESS_HTTP=true
# FHEMMCP_DNS_REBINDING_PROTECTION=false
# Wenn du den Schutz anlässt (true), Host/Origin als Komma-Liste erlauben:
# FHEMMCP_ALLOWED_HOSTS=mcpsolar.example.synology.me
# FHEMMCP_ALLOWED_ORIGINS=https://claude.ai

# OAuth für die claude.ai-App/Desktop (Custom Connector). true = aktiv.
# Bei false bleibt nur der Bearer-Header-Weg (Claude Code).
FHEMMCP_OAUTH_ENABLED=true

# Öffentliche Basis-URL (Issuer/Endpunkte in den OAuth-Discovery-Dokumenten).
# Leer lassen, wenn der Reverse Proxy korrekte X-Forwarded-Proto/-Host-Header
# setzt; sonst hier die externe URL eintragen.
FHEMMCP_PUBLIC_URL=https://mcpsolar.example.synology.me

# --- mcpo (MCP -> OpenAPI Bridge fuer Open WebUI) ---------------------------
# API-Key, mit dem Open WebUI sich bei mcpo authentifiziert (frei waehlbar).
MCPO_API_KEY=change-me-too
# Host-Port, auf dem mcpos OpenAPI veroeffentlicht wird.
MCPO_HOSTPORT=8085
# Pfad zur mcpo-Config auf dem NAS-Host.
MCPO_CONFIG=/volume2/docker/MCP-FHEM-MCPO/config.json
